[resource]
script = ExtResource("1_map")
content_id = &"map.v0"
logical_width = 8000
logical_height = 4000
spawn_node_id = &"node.spawn"
core_node_id = &"node.core"
nodes = Array[LaneNodeDefinition]([SubResource("NodeS"), SubResource("NodeA"), SubResource("NodeB"), SubResource("NodeN1"), SubResource("NodeN2"), SubResource("NodeS1"), SubResource("NodeS2"), SubResource("NodeM"), SubResource("NodeC"), SubResource("NodeG")])
edges = Array[LaneEdgeDefinition]([SubResource("EdgeSA"), SubResource("EdgeAB"), SubResource("EdgeBN1"), SubResource("EdgeN1N2"), SubResource("EdgeN2M"), SubResource("EdgeBS1"), SubResource("EdgeS1S2"), SubResource("EdgeS2M"), SubResource("EdgeMC"), SubResource("EdgeCG")])
routes = Array[RouteDefinition]([SubResource("RouteNorth"), SubResource("RouteSouth")])
build_slots = Array[BuildSlotDefinition]([SubResource("SlotA"), SubResource("SlotN1"), SubResource("SlotN2"), SubResource("SlotS1"), SubResource("SlotS2"), SubResource("SlotC1"), SubResource("SlotC2")])
presentation_scene_path = "res://src/presentation/main.tscn"
