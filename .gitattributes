# Normalize repository text to LF. Godot scene and resource files are text.
* text=auto eol=lf
*.gd text eol=lf
*.tscn text eol=lf
*.tres text eol=lf
*.godot text eol=lf
*.cfg text eol=lf
*.md text eol=lf

# Keep PowerShell scripts in Windows-native form.
*.ps1 text eol=crlf

# Common binary game assets must not be line-ending converted.
*.png binary
*.jpg binary
*.jpeg binary
*.webp binary
*.gif binary
*.ico binary
*.svg text eol=lf
*.wav binary
*.mp3 binary
*.m4a binary
*.flac binary
*.ogg binary
*.glb binary
*.fbx binary
*.blend binary
*.ttf binary
*.otf binary
*.pdf binary

